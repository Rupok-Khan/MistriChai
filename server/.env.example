NODE_ENV=production
TRUST_PROXY=true

DB_HOST=your-aiven-mysql-host.aivencloud.com
DB_PORT=your-aiven-mysql-port
DB_USER=avnadmin
DB_PASSWORD=replace-with-aiven-password
DB_NAME=defaultdb
DB_CONNECTION_LIMIT=10
DB_SSL=true
# Base64-encode the Aiven ca.pem file and paste the single-line result here.
DB_SSL_CA_BASE64=replace-with-base64-encoded-aiven-ca

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
ADMIN_JWT_EXPIRES_IN=12h

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

CORS_ORIGIN=https://your-project.vercel.app
CROSS_SITE_COOKIES=true

CLOUDINARY_REQUIRED=true
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret
